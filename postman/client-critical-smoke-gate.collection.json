  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const fmt = (d) => d.toISOString().slice(0, 10);",
          "const now = new Date();",
          "const existing = new Date(now);",
          "existing.setDate(existing.getDate() + 1);",
          "const created = new Date(now);",
          "created.setDate(created.getDate() + 2);",
          "pm.environment.set('existingBookingDate', fmt(existing));",
          "pm.environment.set('newBookingDate', fmt(created));"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://api.infinite-track.tech",
      "type": "string",
      "description": "Live staging base URL for the client-critical smoke gate."
    }
  ]
}
