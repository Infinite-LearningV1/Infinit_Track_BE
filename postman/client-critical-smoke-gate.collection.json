      "name": "01 Auth",
      "item": [
        {
          "name": "Login - Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('login contract is strict for Admin', () => {",
                  "  pm.expect(body.success).to.eql(true);",
                  "  pm.expect(body).to.not.have.property('code');",
                  "  pm.expect(body.message).to.eql('Login berhasil');",
                  "  pm.expect(body.data).to.be.an('object');",
                  "  pm.expect(body.data.id).to.be.a('number');",
                  "  pm.expect(body.data.full_name).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.data.email).to.eql(pm.variables.get('adminEmail'));",
                  "  pm.expect(body.data.role_name).to.eql('Admin');",
                  "  pm.expect(body.data.position_name).to.be.a('string');",
                  "  pm.expect(body.data.program_name).to.be.a('string');",
                  "  pm.expect(body.data.division_name).to.be.a('string');",
                  "  pm.expect(body.data.nip_nim).to.be.a('string');",
                  "  pm.expect(body.data.phone).to.be.a('string');",
                  "  pm.expect(body.data).to.have.property('photo');",
                  "  pm.expect(body.data).to.have.property('photo_updated_at');",
                  "  pm.expect(body.data.token).to.be.a('string').and.to.have.length.greaterThan(20);",
                  "  pm.expect(body.data.location).to.be.an('object');",
                  "  pm.expect(body.data.location.latitude).to.be.a('number');",
                  "  pm.expect(body.data.location.longitude).to.be.a('number');",
                  "  pm.expect(body.data.location.radius).to.be.a('number');",
                  "});",
                  "pm.environment.set('adminToken', body.data.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "response": []
        },
