# Database Configuration
# Local native MySQL: DB_HOST=localhost,
# Staging droplet target:DB_HOST=<managed-db-host-or-runtime-db-host>, DB_SSL=true only if the DB endpoint requires TLS
DB_HOST=localhost
DB_USER=your_db_username
DB_PASS=your_db_password
DB_NAME=your_db_name
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_ROOT_PASSWORD=rootpassword

# JWT Configuration
# JWT_SECRET is functionally required anywhere auth sign/verify flows are exercised.
JWT_SECRET=your_super_secret_jwt_key
JWT_TTL_SECONDS=86400
JWT_ACCESS_TTL_SECONDS=14400
JWT_REFRESH_SECRET=your_refresh_secret_jwt_key
JWT_REFRESH_TTL_SECONDS=2592000
JWT_REFRESH_INACTIVITY_WINDOW_SECONDS=172800

# Server Configuration
PORT=3000
NODE_ENV=development
TZ=Asia/Jakarta
LOG_LEVEL=info
# Local development may use *, but staging should set the explicit frontend origin.
CORS_ORIGIN=*

# Cloudinary Configuration (canonical runtime keys)
# Active runtime reads these three keys directly; do not replace them with CLOUDINARY_URL.
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Runtime image contract
# Compose runtime should pin an explicit SHA on the droplet; latest is convenience only.
BACKEND_IMAGE_TAG=latest

# Geoapify API Configuration (canonical runtime key)
# Active runtime reads GEOAPIFY_API_KEY; historical GEOAPIFY_KEY references are not the current backend contract.
GEOAPIFY_API_KEY=your_geoapify_api_key_here

# Business Logic Configuration
# Operational attendance settings are stored in DB-backed settings.
# Legacy env keys are only read by the INF-141 bootstrap migration when inserting missing rows.